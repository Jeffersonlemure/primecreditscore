# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Target Informações (Serasa)
TARGET_CLIENT_ID=your-client-id
TARGET_CLIENT_SECRET=your-client-secret
TARGET_AUTH_URL=https://auth.targetinformacoes.com/oauth/token/
TARGET_BASE_URL=https://crednet.targetinformacoes.com/

# Asaas (Pagamentos PIX)
ASAAS_API_KEY=your-asaas-api-key
ASAAS_BASE_URL=https://api.asaas.com/v3

# App
# Quando em produção na Vercel, isso pode ser dinâmico ou fixo no domínio real (ex: https://primescore.com.br)
NEXT_PUBLIC_APP_URL=https://your-production-url.app
